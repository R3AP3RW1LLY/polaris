{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "description": "LODESTAR Electron shell (main/preload) + React/TypeScript/Vite renderer.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./out/main/index.cjs",
  "scripts": {
    "dev": "node scripts/ensure-abi.mjs electron && electron-vite dev",
    "build": "electron-vite build",
    "start": "node scripts/ensure-abi.mjs electron && electron-vite preview",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:e2e": "node scripts/ensure-abi.mjs electron && electron-vite build && playwright test",
    "rebuild:electron": "node scripts/ensure-abi.mjs electron",
    "rebuild:node": "node scripts/ensure-abi.mjs node"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@lodestar/core": "workspace:*",
    "@lodestar/data": "workspace:*",
    "@lodestar/integrations": "workspace:*",
    "@lodestar/overlay": "workspace:*",
    "@lodestar/shared": "workspace:*",
    "@lodestar/voice": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "pino": "^9.13.1",
    "pino-roll": "^3.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.5.2",
    "electron": "^39.2.4",
    "electron-vite": "^4.0.1",
    "framer-motion": "^12.42.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.17",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^3.4.19",
    "vite": "^7.1.12",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "org.lodestar.app",
    "productName": "LODESTAR",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "icon": "build/icon.icns"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  }
}
