    "typecheck": "turbo run typecheck",
    "compliance": "turbo run compliance"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
