{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out/**"]
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "typecheck": {},
    "compliance": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
